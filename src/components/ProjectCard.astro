---
interface Props {
  project: {
    name: string;
    description: string;
    stargazerCount: number;
    url: string;
    updatedAt: string;
    primaryLanguage?: string;
    homepageUrl?: string;
    repositoryTopics?: string[];
  };
}

const { project } = Astro.props as Props;
const updated = new Date(project.updatedAt).toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric"
});
---

<article class="card reveal flex h-full flex-col p-5 hover:-translate-y-0.5">
  <div class="flex items-start">
    <h3 class="project-title text-base font-semibold leading-tight tracking-tight">
      <a class="focus-ring hover:underline" href={project.url} target="_blank" rel="noreferrer">{project.name}</a>
    </h3>
  </div>

  {project.description && <p class="project-description mt-3 text-sm leading-relaxed text-[rgb(var(--muted))]">{project.description}</p>}

  <div class="project-language-row mt-3 flex min-h-[1.75rem] flex-wrap items-start gap-2">
    {project.primaryLanguage && (
      <span class="rounded-full bg-surface-100 px-2.5 py-1 text-xs text-surface-900 dark:bg-surface-900 dark:text-surface-100">{project.primaryLanguage}</span>
    )}
  </div>

  <div class="mt-auto flex items-center justify-between pt-3 text-xs text-[rgb(var(--muted))]">
    <span>Updated {updated}</span>
    <div class="flex items-center gap-3">
      {project.homepageUrl && <a class="focus-ring hover:underline" href={project.homepageUrl} target="_blank" rel="noreferrer">Demo</a>}
      <a class="focus-ring hover:underline" href={project.url} target="_blank" rel="noreferrer">GitHub</a>
    </div>
  </div>
</article>

<style>
  .project-title {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 2.5rem;
  }

  .project-description {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 4.5rem;
  }
</style>

