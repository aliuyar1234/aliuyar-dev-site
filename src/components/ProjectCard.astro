---
interface Props {
  project: {
    name: string;
    description: string;
    stargazerCount: number;
    url: string;
    updatedAt: string;
    primaryLanguage?: string;
    homepageUrl?: string;
    repositoryTopics?: string[];
  };
  index?: number;
}

const { project, index } = Astro.props as Props;
const updated = new Date(project.updatedAt).toLocaleDateString("en-GB", {
  year: "2-digit",
  month: "2-digit",
  day: "2-digit"
}).replace(/\//g, ".");

const idx = typeof index === "number" ? String(index + 1).padStart(2, "0") : null;
const lang = project.primaryLanguage || "—";
const ext = lang === "Python" ? ".py"
  : lang === "TypeScript" ? ".ts"
  : lang === "JavaScript" ? ".js"
  : lang === "Rust" ? ".rs"
  : lang === "Go" ? ".go"
  : lang === "Haskell" ? ".hs"
  : lang === "C" ? ".c"
  : lang === "C++" ? ".cpp"
  : "";
---

<article class="row reveal">
  <div class="idx">
    {idx && <>№ {idx}</>}
  </div>

  <div>
    <h3 class="title">
      <a class="link-accent" href={project.url} target="_blank" rel="noreferrer">
        {project.name}{ext}
      </a>
    </h3>
    {project.description && (
      <p class="desc">{project.description}</p>
    )}
    <div class="mt-3 flex flex-wrap items-center gap-1.5">
      {project.primaryLanguage && <span class="tag">{project.primaryLanguage}</span>}
      {project.homepageUrl && (
        <a class="tag" href={project.homepageUrl} target="_blank" rel="noreferrer">demo</a>
      )}
      <a class="tag" href={project.url} target="_blank" rel="noreferrer">source</a>
    </div>
  </div>

  <div class="meta">
    <div>{updated}</div>
    {project.stargazerCount > 0 && (
      <div class="mt-1" style="color: rgb(var(--accent));">★ {project.stargazerCount}</div>
    )}
  </div>
</article>
