---
interface Props {
  project: {
    name: string;
    description: string;
    stargazerCount: number;
    url: string;
    updatedAt: string;
    primaryLanguage?: string;
    homepageUrl?: string;
    repositoryTopics?: string[];
  };
  index?: number;
}

const { project, index } = Astro.props as Props;
const updatedYear = new Date(project.updatedAt).toLocaleDateString("en-US", { year: "numeric" });
const updatedMonth = new Date(project.updatedAt).toLocaleDateString("en-US", { month: "short" });
const idx = typeof index === "number" ? String(index + 1).padStart(2, "0") : null;
---

<article class="row reveal">
  <div class="idx">
    {idx ? `№ ${idx}` : ""}
  </div>

  <div>
    <h3 class="title">
      <a class="focus-ring title-link" href={project.url} target="_blank" rel="noreferrer">
        {project.name}
      </a>
    </h3>
    {project.description && (
      <p class="desc">{project.description}</p>
    )}
    <div class="mt-4 flex flex-wrap items-center gap-2">
      {project.primaryLanguage && <span class="chip">{project.primaryLanguage}</span>}
      {project.homepageUrl && (
        <a class="chip focus-ring" href={project.homepageUrl} target="_blank" rel="noreferrer">Demo ↗</a>
      )}
      <a class="chip focus-ring" href={project.url} target="_blank" rel="noreferrer">Source ↗</a>
    </div>
  </div>

  <div class="meta">
    <div>{updatedMonth} {updatedYear}</div>
    {project.stargazerCount > 0 && (
      <div class="mt-1 tabnum" style="color: rgb(var(--muted-2));">★ {project.stargazerCount}</div>
    )}
  </div>
</article>
