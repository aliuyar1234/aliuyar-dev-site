---
const links = [
  { href: "/projects", label: "Projects" },
  { href: "/research", label: "Research" },
  { href: "/articles", label: "Articles" },
  { href: "/services", label: "Services" },
  { href: "/contact", label: "Contact" }
];

const currentPathRaw = Astro.url.pathname || "/";
const currentPath = currentPathRaw === "/" ? "/" : currentPathRaw.replace(/\/+$/, "");

const normalizeHref = (href: string) => {
  const path = href.split("#")[0] || "/";
  return path === "/" ? "/" : path.replace(/\/+$/, "");
};

const isActiveLink = (href: string) => currentPath === normalizeHref(href);

const desktopLinkClass = (href: string) =>
  [
    "focus-ring rounded-full px-3 py-1.5 text-sm transition-colors",
    isActiveLink(href)
      ? "bg-surface-100 text-[rgb(var(--fg))] dark:bg-surface-900"
      : "text-[rgb(var(--muted))] hover:bg-surface-100 hover:text-[rgb(var(--fg))] dark:hover:bg-surface-900"
  ].join(" ");

const mobileLinkClass = (href: string) =>
  [
    "focus-ring rounded-lg px-3 py-2 text-sm transition-colors",
    isActiveLink(href)
      ? "bg-surface-100 text-[rgb(var(--fg))] dark:bg-surface-900"
      : "text-[rgb(var(--muted))] hover:bg-surface-100 hover:text-[rgb(var(--fg))] dark:hover:bg-surface-900"
  ].join(" ");
---

<header class="sticky top-0 z-50 border-b border-[rgb(var(--border))] bg-[rgb(var(--bg))/0.85] backdrop-blur-xl">
  <nav class="page-wrap flex items-center justify-between py-4" aria-label="Main">
    <a class="focus-ring text-sm font-semibold tracking-tight" href="/">aliuyar.dev</a>

    <ul class="hidden items-center gap-1 rounded-full border border-[rgb(var(--border))] bg-[rgb(var(--card))/0.72] px-2 py-1 md:flex">
      {links.map((link) => (
        <li>
          <a class={desktopLinkClass(link.href)} href={link.href} aria-current={isActiveLink(link.href) ? "page" : undefined}>
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-2">
      <a
        href="/cv"
        class="focus-ring hidden rounded-full border border-[rgb(var(--border))] px-3.5 py-2 text-xs font-medium text-[rgb(var(--fg))] transition-colors hover:bg-surface-100 dark:hover:bg-surface-900 md:inline-flex"
      >
        Download CV
      </a>
      <button id="theme-toggle" type="button" class="focus-ring rounded-full border border-[rgb(var(--border))] px-3.5 py-2 text-xs font-medium text-[rgb(var(--muted))] transition-colors hover:text-[rgb(var(--fg))]" aria-label="Toggle color theme" aria-pressed="false">
        Theme
      </button>
      <button
        id="mobile-menu-toggle"
        type="button"
        class="focus-ring rounded-full border border-[rgb(var(--border))] px-3.5 py-2 text-xs font-medium text-[rgb(var(--muted))] transition-colors hover:text-[rgb(var(--fg))] md:hidden"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        Menu
      </button>
    </div>
  </nav>
  <div id="mobile-menu" class="hidden border-t border-[rgb(var(--border))] md:hidden">
    <div class="page-wrap flex flex-col gap-2 py-3">
      {links.map((link) => (
        <a class={mobileLinkClass(link.href)} href={link.href} aria-current={isActiveLink(link.href) ? "page" : undefined}>
          {link.label}
        </a>
      ))}
      <a
        class="focus-ring mt-1 inline-flex w-full items-center justify-center rounded-full border border-[rgb(var(--border))] px-4 py-2 text-sm font-semibold text-[rgb(var(--fg))] transition-colors hover:bg-surface-100 dark:hover:bg-surface-900"
        href="/cv"
      >
        Download CV
      </a>
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    const button = document.getElementById("theme-toggle");
    if (!button) return;

    const key = "theme";
    const root = document.documentElement;
    const getTheme = () => (root.classList.contains("dark") ? "dark" : "light");

    const update = () => {
      const theme = getTheme();
      button.setAttribute("aria-pressed", String(theme === "dark"));
      button.textContent = theme === "dark" ? "Light" : "Dark";
    };

    button.addEventListener("click", () => {
      const next = getTheme() === "dark" ? "light" : "dark";
      root.classList.toggle("dark", next === "dark");
      localStorage.setItem(key, next);
      update();
    });

    update();
  })();

  (() => {
    const menu = document.getElementById("mobile-menu");
    const toggle = document.getElementById("mobile-menu-toggle");
    if (!menu || !toggle) return;

    const closeMenu = () => {
      menu.classList.add("hidden");
      toggle.setAttribute("aria-expanded", "false");
      toggle.textContent = "Menu";
    };

    toggle.addEventListener("click", () => {
      const isOpen = !menu.classList.contains("hidden");
      if (isOpen) {
        closeMenu();
        return;
      }

      menu.classList.remove("hidden");
      toggle.setAttribute("aria-expanded", "true");
      toggle.textContent = "Close";
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => closeMenu());
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeMenu();
    });
  })();
</script>
