---
import profile from "../content/profile.json";

const hasLinkedIn = Boolean(profile.linkedin && !profile.linkedin.includes("your-linkedin-handle"));
---

<footer class="mt-24 border-t border-[rgb(var(--border))]">
  <div class="page-wrap flex flex-col items-start justify-between gap-3 py-8 text-sm text-[rgb(var(--muted))] md:flex-row md:items-center">
    <p>© {new Date().getFullYear()} {profile.name}.</p>
    <div class="flex items-center gap-4">
      <a class="focus-ring transition-colors hover:text-[rgb(var(--fg))]" href={profile.github} target="_blank" rel="noreferrer">GitHub</a>
      {hasLinkedIn && (
        <a class="focus-ring transition-colors hover:text-[rgb(var(--fg))]" href={profile.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
      )}
      <a class="focus-ring transition-colors hover:text-[rgb(var(--fg))]" href="/contact">Contact</a>
    </div>
  </div>
</footer>
