---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import writing from "../../content/writing.json";

interface BlogPost {
  title: string;
  date: string;
  summary: string;
  slug: string;
  tags?: string[];
  readMinutes?: number;
}

const posts = [...(writing as BlogPost[])].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric"
  });

const articlesJsonLd = posts.map((post) => ({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  datePublished: new Date(post.date).toISOString(),
  description: post.summary,
  url: `https://aliuyar.dev/articles/${post.slug}`,
  isPartOf: {
    "@type": "Blog",
    name: "Ali Uyar Articles",
    url: "https://aliuyar.dev/articles"
  }
}));
---

<BaseLayout
  title="Articles — Ali Uyar"
  canonicalPath="/articles"
  description="Articles on reliable AI systems, product strategy, and practical delivery."
  jsonLd={articlesJsonLd}
>
  <SiteHeader />
  <main id="main" class="page-wrap py-16 md:py-24">
    <section class="grid items-end gap-10 md:grid-cols-12">
      <div class="md:col-span-9">
        <p class="edition">№ 05 / Writing</p>
        <h1 class="display title-balance mt-6 text-[clamp(2.5rem,7vw,6rem)]">
          Articles<span class="display-italic" style="color: rgb(var(--muted));">.</span>
        </h1>
        <p class="page-lede">
          Essays on AI systems, product decisions, and the constraints that shape them.
        </p>
      </div>
      <div class="md:col-span-3">
        <div class="border-t rule pt-6">
          <p class="eyebrow">Count</p>
          <div class="mt-4 flex items-baseline justify-between">
            <span class="font-mono text-[0.72rem] uppercase tracking-[0.2em]" style="color: rgb(var(--muted));">Essays</span>
            <span class="font-display tabnum text-[1.5rem]" style="font-weight: 440;">{String(posts.length).padStart(2, "0")}</span>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-14">
      {posts.map((post, i) => (
        <article class="row reveal">
          <div class="idx tabnum">№ {String(i + 1).padStart(2, "0")}</div>
          <div>
            <h2 class="title">
              <a class="focus-ring title-link" href={`/articles/${post.slug}`}>
                {post.title}
              </a>
            </h2>
            <p class="desc">{post.summary}</p>
            {(post.tags || []).length > 0 && (
              <div class="mt-4 flex flex-wrap gap-2">
                {(post.tags || []).map((tag) => <span class="chip">{tag}</span>)}
              </div>
            )}
          </div>
          <div class="meta">
            <div>{formatDate(post.date)}</div>
            {post.readMinutes && (
              <div class="mt-1 tabnum" style="color: rgb(var(--muted-2));">{post.readMinutes} min</div>
            )}
          </div>
        </article>
      ))}
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
