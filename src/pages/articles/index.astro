---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import writing from "../../content/writing.json";

interface BlogPost {
  title: string;
  date: string;
  summary: string;
  slug: string;
  tags?: string[];
  readMinutes?: number;
}

const posts = [...(writing as BlogPost[])].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

const formatDate = (date: string) => {
  const d = new Date(date);
  return d.toLocaleDateString("en-GB", { year: "numeric", month: "2-digit", day: "2-digit" }).replace(/\//g, ".");
};

const articlesJsonLd = posts.map((post) => ({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  datePublished: new Date(post.date).toISOString(),
  description: post.summary,
  url: `https://aliuyar.dev/articles/${post.slug}`,
  isPartOf: {
    "@type": "Blog",
    name: "Ali Uyar Articles",
    url: "https://aliuyar.dev/articles"
  }
}));
---

<BaseLayout
  title="ali uyar // articles"
  canonicalPath="/articles"
  description="Articles on reliable AI systems, product strategy, and practical delivery."
  jsonLd={articlesJsonLd}
>
  <SiteHeader />
  <main id="main" class="page-wrap py-14 md:py-16">

    <section class="reveal">
      <p class="prompt mono-sm tabnum" style="text-transform: uppercase; letter-spacing: 0.12em; color: rgb(var(--muted));">
        ls ~/writing
      </p>
      <h1 class="page-title mt-6">articles<span class="caret" aria-hidden="true"></span></h1>
      <p class="mt-5 max-w-2xl copy-pretty" style="color: rgb(var(--muted)); line-height: 1.75;">
        Essays on AI systems, product decisions, strange problem shapes, and the parts people usually notice too late.
      </p>
      <dl class="kv mt-8 max-w-sm">
        <dt>COUNT</dt>
        <dd class="tabnum accent">{String(posts.length).padStart(2, "0")}</dd>
        <dt>FORMAT</dt>
        <dd>long-form · essay</dd>
      </dl>
    </section>

    <div class="divider-ascii mt-12" aria-hidden="true">
      ────────────────────────────────────────────────────────────────────────────
    </div>

    <section class="mt-2">
      {posts.map((post, i) => (
        <article class="row reveal">
          <div class="idx">
            № {String(i + 1).padStart(2, "0")}<br />
            <span style="color: rgb(var(--dim));">{formatDate(post.date)}</span>
          </div>
          <div>
            <h2 class="title">
              <a class="link-accent" href={`/articles/${post.slug}`}>
                {post.title}
              </a>
            </h2>
            <p class="desc">{post.summary}</p>
            {(post.tags || []).length > 0 && (
              <div class="mt-3 flex flex-wrap gap-1.5">
                {(post.tags || []).map((tag) => <span class="tag">{tag}</span>)}
              </div>
            )}
          </div>
          <div class="meta">
            {post.readMinutes && <div>~ {post.readMinutes}m</div>}
          </div>
        </article>
      ))}
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
