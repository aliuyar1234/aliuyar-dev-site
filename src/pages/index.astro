---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ProjectCard from "../components/ProjectCard.astro";
import projects from "../content/projects.json";
import featured from "../content/featured.json";
import research from "../content/research.json";
import caseStudies from "../content/case_studies.json";
import writing from "../content/writing.json";
import profile from "../content/profile.json";
import { filterProductProjects } from "../utils/researchSplit";

const featuredNames = new Set(featured.map((item) => item.name));
const nonResearchProjects = filterProductProjects(projects, research);
const featuredProjects = nonResearchProjects.filter((p) => featuredNames.has(p.name)).slice(0, 5);
const fallbackProjects = nonResearchProjects.slice(0, 5);
const cards = featuredProjects.length > 0 ? featuredProjects : fallbackProjects;
const topResearch = research.slice(0, 3);
const startHere = writing.find((post) => post.slug === "the-first-answer-is-usually-not-the-real-one") || writing[0];

const principles = [
  {
    k: "01",
    t: "Find the constraint",
    b: "A model problem may be a data problem. A dashboard problem may be a question problem. A strategy problem may be an avoided tradeoff. I like getting to the layer where the work actually changes."
  },
  {
    k: "02",
    t: "Keep the evidence close",
    b: "If a system makes a claim, routes a case, blocks an action, or changes a workflow, there should be something to inspect afterwards. Otherwise people are guessing politely."
  },
  {
    k: "03",
    t: "Cut the machinery",
    b: "Complexity has to earn its place. Sometimes the right move is a model, sometimes cleaner data, sometimes a better decision loop, and sometimes not adding AI at all."
  }
];

const thinking = [
  "The first answer is useful, but it is often incomplete.",
  "Do not fix a data problem with a prompt.",
  "Do not fix an ownership problem with a dashboard.",
  "Do not fix a judgment problem by adding more automation.",
  "Evals should answer product questions, not decorate dashboards.",
  "Find the real constraint, then make the output simple enough to use."
];

const notItems = [
  "Not an AI hype guy.",
  "Not a just-add-agents person.",
  "Not pretending every problem needs a model.",
  "Not an agency machine.",
  "Not impressed by demos that cannot explain their own failures."
];
---

<BaseLayout
  title="ali uyar // ai systems & technical product"
  canonicalPath="/"
  description="AI systems, product decisions, workflows, evaluation, governance, and the judgment that connects them."
>
  <SiteHeader />

  <main id="main">
    {/* ═════════ HERO / boot sequence ═════════ */}
    <section class="page-wrap pt-12 md:pt-16 pb-14">
      <div class="reveal-stagger">
        <p class="mono-xs comment" style="text-transform: none; letter-spacing: 0;">// initialising …</p>
        <p class="mono-xs comment" style="text-transform: none; letter-spacing: 0;">// session ok</p>

        <div class="mt-10">
          <dl class="kv max-w-xl">
            <dt>NAME</dt>
            <dd>Ali Uyar</dd>
            <dt>ROLE</dt>
            <dd>AI Systems / Product</dd>
            <dt>LOCUS</dt>
            <dd>{profile.location} · UTC+01</dd>
            <dt>STATE</dt>
            <dd><span class="accent">●</span> In a full-time role</dd>
          </dl>
        </div>

        <div class="mt-12">
          <p class="prompt-plain mono-xs tabnum" style="text-transform: uppercase; letter-spacing: 0.12em; color: rgb(var(--accent));">objective</p>
          <h1 class="hero-title mt-5">
            <span class="glyph">I work on problems</span><br />
            that look simple until you get close.<br />
            AI systems, product decisions, workflows, evaluation,<br />
            governance, and the judgment that connects them.<span class="caret" aria-hidden="true"></span>
          </h1>
        </div>

        <div class="mt-10 flex flex-wrap items-center gap-3">
          <a href="/projects" class="btn-accent">run projects</a>
          <a href="/contact" class="btn">send email</a>
        </div>
      </div>
    </section>

    {/* ═════════ DIVIDER ═════════ */}
    <div class="page-wrap">
      <div class="divider-ascii" aria-hidden="true">
        ════════════════════════════════════════════════════════════════════════════
      </div>
    </div>

    {/* ═════════ § 01 · PRINCIPLES ═════════ */}
    <section class="page-wrap mt-14">
      <div class="section-head">
        <span class="section-num">§ 01</span>
        <span class="section-name">Principles</span>
        <span class="section-meta">[ 03 · invariant ]</span>
      </div>
      <div class="grid gap-8 md:grid-cols-3 md:gap-10 reveal">
        {principles.map((p) => (
          <article>
            <p class="mono-xs tabnum" style="color: rgb(var(--accent));">{p.k}/03</p>
            <h3 class="mt-3 font-mono text-[1.02rem]" style="font-weight: 500; letter-spacing: -0.005em;">{p.t}</h3>
            <p class="mt-3 text-[0.92rem] leading-[1.7]" style="color: rgb(var(--muted));">{p.b}</p>
          </article>
        ))}
      </div>
    </section>

    {/* ═════════ § 02 · HOW I THINK ═════════ */}
    <section class="page-wrap mt-20">
      <div class="section-head">
        <span class="section-num">§ 02</span>
        <span class="section-name">How I think</span>
        <span class="section-meta">[ operating notes ]</span>
      </div>
      <div class="grid gap-8 md:grid-cols-12 md:gap-12 reveal">
        <div class="md:col-span-5 measure">
          <p class="mono-xs comment" style="text-transform: none; letter-spacing: 0;">
            // the layer where the problem lives
          </p>
          <p class="mt-5 text-[1rem] leading-[1.75]">
            I care about the layer where the problem actually lives.
          </p>
          <p class="mt-5 text-[1rem] leading-[1.75]" style="color: rgb(var(--muted));">
            The visible failure might be the model, the data, the workflow, the metric, the incentive, or the decision nobody wants to make. The work is finding the real constraint, then making the answer simple enough to use.
          </p>
        </div>
        <div class="md:col-span-7 grid gap-3">
          {thinking.map((item, i) => (
            <div class="flex gap-3" style="border-top: 1px solid var(--rule); padding-top: 0.85rem;">
              <span class="mono-xs tabnum" style="color: rgb(var(--accent));">{String(i + 1).padStart(2, "0")}</span>
              <p class="font-mono text-[0.95rem] leading-[1.6]" style="color: rgb(var(--muted));">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ═════════ § 03 · START HERE ═════════ */}
    <section class="page-wrap mt-20">
      <div class="section-head">
        <span class="section-num">§ 03</span>
        <span class="section-name">Start here</span>
        <a href={`/articles/${startHere.slug}`} class="section-meta link-muted">[ read article → ]</a>
      </div>
      <article class="reveal" style="border: 1px solid var(--rule-strong); padding: 1.5rem;">
        <p class="label">[ flagship note ]</p>
        <h2 class="mt-4 font-mono text-[1.35rem] md:text-[1.7rem]" style="font-weight: 500; letter-spacing: -0.01em; line-height: 1.35;">
          <a class="link-accent" href={`/articles/${startHere.slug}`}>{startHere.title}</a>
        </h2>
        <p class="mt-4 max-w-2xl text-[1rem] leading-[1.75]" style="color: rgb(var(--muted));">{startHere.summary}</p>
      </article>
    </section>

    {/* ═════════ § 04 · RESEARCH ═════════ */}
    <section class="page-wrap mt-20">
      <div class="section-head">
        <span class="section-num">§ 04</span>
        <span class="section-name">Research</span>
        <a href="/research" class="section-meta link-muted">[ all papers → ]</a>
      </div>
      <div>
        {topResearch.map((paper, i) => (
          <article class="row reveal">
            <div class="idx">№ {String(i + 1).padStart(2, "0")}</div>
            <div>
              <h3 class="title">
                <a class="link-accent" href={paper.pdfUrl || paper.paperUrl} target="_blank" rel="noreferrer">
                  {paper.title}.pdf
                </a>
              </h3>
              <p class="desc">{paper.whyItMatters || paper.abstract}</p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {(paper.tags || []).map((tag) => <span class="tag">{tag}</span>)}
              </div>
            </div>
            <div class="meta">
              <div>{paper.year}</div>
              <div class="mt-1">{paper.venue}</div>
            </div>
          </article>
        ))}
      </div>
    </section>

    {/* ═════════ § 03 · PROJECTS ═════════ */}
    <section class="page-wrap mt-20">
      <div class="section-head">
        <span class="section-num">§ 05</span>
        <span class="section-name">Selected projects</span>
        <a href="/projects" class="section-meta link-muted">[ ls /projects → ]</a>
      </div>
      <div>
        {cards.map((project, i) => <ProjectCard project={project} index={i} />)}
      </div>
    </section>

    {/* ═════════ § 04 · OUTCOMES ═════════ */}
    <section class="page-wrap mt-20">
      <div class="section-head">
        <span class="section-num">§ 06</span>
        <span class="section-name">Outcomes</span>
        <span class="section-meta">[ problem · build · result ]</span>
      </div>
      <div class="grid gap-6 md:grid-cols-3 md:gap-8">
        {caseStudies.map((item, i) => (
          <article class="reveal" style="border: 1px solid var(--rule); padding: 1.25rem;">
            <p class="mono-xs tabnum" style="color: rgb(var(--accent));">case_{String(i + 1).padStart(2, "0")}</p>
            <h3 class="mt-4 font-mono text-[1.05rem]" style="font-weight: 500; letter-spacing: -0.005em;">{item.title}</h3>
            <dl class="mt-5 space-y-4 text-[0.88rem] leading-[1.7]">
              <div>
                <dt class="label">problem</dt>
                <dd class="mt-1" style="color: rgb(var(--muted));">{item.problem}</dd>
              </div>
              <div>
                <dt class="label">build</dt>
                <dd class="mt-1" style="color: rgb(var(--muted));">{item.build}</dd>
              </div>
              <div>
                <dt class="label">result</dt>
                <dd class="mt-1" style="color: rgb(var(--muted));">{item.result}</dd>
              </div>
            </dl>
            <a href={item.projectUrl} target="_blank" rel="noreferrer" class="mt-5 inline-flex link-accent mono-sm">
              → {item.projectName}
            </a>
          </article>
        ))}
      </div>
    </section>

    {/* ═════════ § 05 · FOCUS ═════════ */}
    <section class="page-wrap mt-24">
      <div class="section-head">
        <span class="section-num">§ 07</span>
        <span class="section-name">Focus</span>
        <span class="section-meta">[ how i work ]</span>
      </div>
      <div class="grid gap-10 md:grid-cols-12 md:gap-12">
        <div class="md:col-span-7 measure">
          <p class="mono-xs comment" style="text-transform: none; letter-spacing: 0;">
            // after the demo, in the weather
          </p>
          <p class="mt-5 text-[1rem] leading-[1.75]">
            I care about the moment when an AI idea stops being exciting and starts becoming operational. What should it be trusted to do? Where should it fail closed? What evidence would make a decision defensible later?
          </p>
          <p class="mt-5 text-[1rem] leading-[1.75]" style="color: rgb(var(--muted));">
            That usually sits between engineering, product, and delivery. I like clear questions, small loops, and work that leaves the system less mysterious than it was before.
          </p>
        </div>
        <aside class="md:col-span-5">
          <div style="border: 1px solid var(--rule-strong); padding: 1.5rem;">
            <p class="label">[ if this seems relevant ]</p>
            <h3 class="mt-3 font-mono text-[1.05rem]" style="font-weight: 500; line-height: 1.5;">
              Send the rough version. Context beats polish.
            </h3>
            <p class="mt-4 text-[0.9rem] leading-[1.7]" style="color: rgb(var(--muted));">
              Tell me what you are building, what feels stuck, and what decision you are trying to make.
            </p>
            <a href="/contact" class="btn-accent mt-6">open thread</a>
          </div>
        </aside>
      </div>
    </section>

    {/* ═════════ § 08 · NOT THIS ═════════ */}
    <section class="page-wrap mt-20">
      <div class="section-head">
        <span class="section-num">§ 08</span>
        <span class="section-name">What I am not</span>
        <span class="section-meta">[ useful boundaries ]</span>
      </div>
      <div class="grid gap-8 md:grid-cols-12 md:gap-12 reveal">
        <div class="md:col-span-5 measure">
          <p class="text-[1rem] leading-[1.75]">
            This is partly taste and partly self-defense. The AI space rewards confident nonsense too easily.
          </p>
          <p class="mt-5 text-[1rem] leading-[1.75]" style="color: rgb(var(--muted));">
            I would rather be useful, precise, and occasionally annoying than sound important while making the system worse.
          </p>
        </div>
        <div class="md:col-span-7 grid gap-3">
          {notItems.map((item) => (
            <p class="font-mono text-[0.95rem] leading-[1.6]" style="border-top: 1px solid var(--rule); padding-top: 0.85rem; color: rgb(var(--muted));">
              <span class="accent">›</span> {item}
            </p>
          ))}
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
