---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ProjectCard from "../components/ProjectCard.astro";
import projects from "../content/projects.json";
import featured from "../content/featured.json";
import research from "../content/research.json";
import caseStudies from "../content/case_studies.json";
import { filterProductProjects } from "../utils/researchSplit";

const featuredNames = new Set(featured.map((item) => item.name));
const nonResearchProjects = filterProductProjects(projects, research);
const featuredProjects = nonResearchProjects.filter((p) => featuredNames.has(p.name)).slice(0, 6);
const fallbackProjects = nonResearchProjects.slice(0, 6);
const cards = featuredProjects.length > 0 ? featuredProjects : fallbackProjects;
const topResearch = research.slice(0, 3);
---

<BaseLayout
  title="Ali Uyar | AI Systems & Product"
  canonicalPath="/"
  description="AI systems and technical product work focused on reliability, evidence, and decisions that age well."
>
  <SiteHeader />

  <main id="main" class="page-wrap">
    <section id="work" class="reveal pt-16 md:pt-24">
      <p class="text-sm tracking-tight text-[rgb(var(--muted))]">Ali Uyar / AI systems / technical product</p>
      <h1 class="title-balance mt-4 max-w-4xl text-4xl font-semibold tracking-tight md:text-7xl">I build AI products that hold up in practice.</h1>
      <p class="page-lede max-w-3xl">My work focuses on reliability, evaluation, and technical decisions that still make sense once a prototype meets real constraints.</p>
      <div class="mt-8 flex flex-wrap items-center gap-5">
        <a href="/projects" class="text-link">Projects</a>
        <a href="/research" class="text-link">Research</a>
      </div>
    </section>

    <section class="reveal mt-14 home-principles">
      <article class="home-principle">
        <h2>Built for pressure</h2>
        <p>Deterministic workflows, clearer failure modes, and decisions that do not collapse once the system has real users and real stakes.</p>
      </article>
      <article class="home-principle">
        <h2>Evidence before confidence</h2>
        <p>Evaluation, traceability, and auditability belong in the product itself, not as reassurance added later.</p>
      </article>
      <article class="home-principle">
        <h2>Product judgment over theatre</h2>
        <p>Useful AI systems come from better sequencing, better constraints, and clearer choices, not just a more polished demo.</p>
      </article>
    </section>

    <section class="mt-20 section-shell">
      <div class="mb-6 flex items-end justify-between gap-4">
        <h2 class="text-2xl font-semibold tracking-tight md:text-4xl">Research</h2>
        <a href="/research" class="section-link">See all</a>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {topResearch.map((paper) => {
          return (
          <article class="subtle-card p-5">
            <h3 class="text-lg font-semibold tracking-tight">{paper.title}</h3>
            <p class="mt-2 text-sm text-[rgb(var(--muted))]">{paper.whyItMatters || paper.abstract}</p>
          </article>
        )})}
      </div>
    </section>

    <section class="mt-20 section-shell">
      <div class="mb-6 flex items-end justify-between gap-4">
        <h2 class="text-2xl font-semibold tracking-tight md:text-4xl">Featured Projects</h2>
        <a href="/projects" class="section-link">See all</a>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {cards.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>

    <section class="mt-20 section-shell">
      <div class="mb-6 flex items-end justify-between gap-4">
        <h2 class="text-2xl font-semibold tracking-tight md:text-4xl">Selected Outcomes</h2>
        <a href="/projects" class="section-link">View work</a>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {caseStudies.map((item) => (
          <article class="subtle-card p-5">
            <h3 class="text-lg font-semibold tracking-tight">{item.title}</h3>
            <p class="mt-3 text-xs font-medium uppercase tracking-wide text-[rgb(var(--muted))]">Problem</p>
            <p class="mt-1 text-sm text-[rgb(var(--muted))]">{item.problem}</p>
            <p class="mt-3 text-xs font-medium uppercase tracking-wide text-[rgb(var(--muted))]">What I Built</p>
            <p class="mt-1 text-sm text-[rgb(var(--muted))]">{item.build}</p>
            <p class="mt-3 text-xs font-medium uppercase tracking-wide text-[rgb(var(--muted))]">Result</p>
            <p class="mt-1 text-sm text-[rgb(var(--muted))]">{item.result}</p>
            <a href={item.projectUrl} target="_blank" rel="noreferrer" class="text-link mt-4">
              {item.projectName}
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-20 grid gap-6 md:grid-cols-5">
      <div class="home-note md:col-span-3">
        <h2 class="text-2xl font-semibold tracking-tight md:text-4xl">What I focus on</h2>
        <p class="mt-4 max-w-2xl">When a team is past the demo stage and trying to make something dependable: what the system should be trusted to do, where evidence should exist, and which trade-offs are worth making.</p>
        <p class="mt-4 max-w-2xl">That tends to sit between engineering, product, and delivery. I like small teams, clear questions, and work that leaves a system easier to understand than it was before.</p>
      </div>
      <aside class="subtle-card md:col-span-2 p-6">
        <h3 class="text-xl font-semibold tracking-tight">If this seems relevant, write to me.</h3>
        <p class="mt-3 text-sm leading-7 text-[rgb(var(--muted))]">A short note with context is enough. I read everything myself and prefer starting from a real problem, not a polished pitch.</p>
        <a href="/contact" class="text-link mt-5">Contact</a>
      </aside>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
