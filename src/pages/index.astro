---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ProjectCard from "../components/ProjectCard.astro";
import projects from "../content/projects.json";
import featured from "../content/featured.json";
import research from "../content/research.json";
import caseStudies from "../content/case_studies.json";
import profile from "../content/profile.json";
import { filterProductProjects } from "../utils/researchSplit";

const featuredNames = new Set(featured.map((item) => item.name));
const nonResearchProjects = filterProductProjects(projects, research);
const featuredProjects = nonResearchProjects.filter((p) => featuredNames.has(p.name)).slice(0, 5);
const fallbackProjects = nonResearchProjects.slice(0, 5);
const cards = featuredProjects.length > 0 ? featuredProjects : fallbackProjects;
const topResearch = research.slice(0, 3);

const counts = {
  projects: nonResearchProjects.length,
  research: research.length,
  articles: 0
};

const principles = [
  {
    title: "Built for pressure",
    body: "Deterministic workflows, clearer failure modes, and decisions that do not collapse once the system has real users and real stakes."
  },
  {
    title: "Evidence before confidence",
    body: "Evaluation, traceability, and auditability belong in the product itself, not as reassurance added later."
  },
  {
    title: "Judgment over theatre",
    body: "Useful AI systems come from better sequencing, better constraints, and clearer choices, not just a more polished demo."
  }
];

const tags = [
  "LLM reliability",
  "evaluation",
  "evidence-driven",
  "determinism",
  "auditability",
  "governance",
  "retrieval",
  "KV-cache",
  "compliance",
  "traceability",
  "small-team delivery",
  "technical product"
];
---

<BaseLayout
  title="Ali Uyar — AI Systems & Technical Product"
  canonicalPath="/"
  description="AI systems and technical product work focused on reliability, evidence, and decisions that age well."
>
  <SiteHeader />

  <main id="main">
    {/* ——— HERO ——— */}
    <section class="page-wrap pt-16 md:pt-24 pb-14 md:pb-20">
      <div class="grid items-end gap-10 md:grid-cols-12">
        <div class="md:col-span-8 reveal-stagger">
          <div class="flex items-center gap-3">
            <span class="status-dot" aria-hidden="true"></span>
            <p class="eyebrow tabnum">Available for select work · {profile.location}</p>
          </div>

          <h1 class="display title-balance mt-8 text-[clamp(2.75rem,8.6vw,7.5rem)]">
            AI products<br />
            <span style="color: rgb(var(--muted));">that hold up in</span>
            <span class="display-italic">practice.</span>
          </h1>

          <p class="page-lede">
            I build, evaluate, and audit AI systems — retrieval, agents, and model-reliant workflows — where reliability, evidence, and technical judgment matter more than the demo.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-4">
            <a href="/projects" class="btn-primary">View Work →</a>
            <a href="/contact" class="btn-secondary">Get in touch</a>
          </div>
        </div>

        <aside class="md:col-span-4">
          <div class="border-t rule pt-6">
            <p class="eyebrow">Index</p>
            <dl class="mt-4 divide-y" style="border-color: var(--rule);">
              <div class="flex items-baseline justify-between py-3">
                <dt class="font-mono text-[0.72rem] uppercase tracking-[0.2em]" style="color: rgb(var(--muted));">Projects</dt>
                <dd class="font-display tabnum text-[1.4rem]" style="font-weight: 440;">{String(counts.projects).padStart(2, "0")}</dd>
              </div>
              <div class="flex items-baseline justify-between py-3 border-t rule">
                <dt class="font-mono text-[0.72rem] uppercase tracking-[0.2em]" style="color: rgb(var(--muted));">Papers</dt>
                <dd class="font-display tabnum text-[1.4rem]" style="font-weight: 440;">{String(research.length).padStart(2, "0")}</dd>
              </div>
              <div class="flex items-baseline justify-between py-3 border-t rule">
                <dt class="font-mono text-[0.72rem] uppercase tracking-[0.2em]" style="color: rgb(var(--muted));">Edition</dt>
                <dd class="font-display tabnum text-[1.4rem]" style="font-weight: 440;">{new Date().getFullYear()}.Ⅰ</dd>
              </div>
            </dl>
          </div>

          <div class="mt-6 border-t rule pt-6">
            <p class="eyebrow">Signals</p>
            <p class="mt-3 text-[0.92rem] leading-[1.7]" style="color: rgb(var(--muted));">
              Writing about reliability, evaluation, and the trade-offs of post-demo AI delivery.
            </p>
            <a href="/articles" class="text-link mt-4">Read essays</a>
          </div>
        </aside>
      </div>
    </section>

    {/* ——— TAG DRIFT ——— */}
    <section aria-hidden="true" class="overflow-hidden border-y rule py-4" style="background: rgb(var(--bg-soft) / 0.6);">
      <div class="flex whitespace-nowrap gap-12 marquee-track" style="width: max-content;">
        {[...tags, ...tags].map((t) => (
          <span class="font-mono text-[0.78rem] uppercase tracking-[0.22em]" style="color: rgb(var(--muted));">
            · {t}
          </span>
        ))}
      </div>
    </section>

    {/* ——— PRINCIPLES ——— */}
    <section class="page-wrap mt-16 md:mt-24">
      <div class="section-head">
        <span class="edition">№ 01</span>
        <h2 class="display">Principles</h2>
        <span class="edition hidden md:inline">Three, no more</span>
      </div>
      <div class="grid gap-10 md:grid-cols-3 md:gap-14">
        {principles.map((p, i) => (
          <article class="home-principle reveal">
            <p class="num tabnum">{String(i + 1).padStart(2, "0")} /</p>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </article>
        ))}
      </div>
    </section>

    {/* ——— RESEARCH ——— */}
    <section class="page-wrap mt-20 md:mt-28">
      <div class="section-head">
        <span class="edition">№ 02</span>
        <h2 class="display">Research</h2>
        <a href="/research" class="section-link">All papers →</a>
      </div>
      <div>
        {topResearch.map((paper, i) => (
          <article class="row reveal">
            <div class="idx tabnum">№ {String(i + 1).padStart(2, "0")}</div>
            <div>
              <h3 class="title">{paper.title}</h3>
              <p class="desc">{paper.whyItMatters || paper.abstract}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {(paper.tags || []).map((tag) => <span class="chip">{tag}</span>)}
              </div>
            </div>
            <div class="meta">
              <div>{paper.venue}</div>
              <div class="mt-1 tabnum" style="color: rgb(var(--muted-2));">{paper.year}</div>
            </div>
          </article>
        ))}
      </div>
    </section>

    {/* ——— FEATURED PROJECTS ——— */}
    <section class="page-wrap mt-20 md:mt-28">
      <div class="section-head">
        <span class="edition">№ 03</span>
        <h2 class="display">Selected Projects</h2>
        <a href="/projects" class="section-link">All projects →</a>
      </div>
      <div>
        {cards.map((project, i) => <ProjectCard project={project} index={i} />)}
      </div>
    </section>

    {/* ——— CASE STUDIES ——— */}
    <section class="page-wrap mt-20 md:mt-28">
      <div class="section-head">
        <span class="edition">№ 04</span>
        <h2 class="display">Outcomes</h2>
        <span class="edition hidden md:inline">Problem · Build · Result</span>
      </div>
      <div class="grid gap-8 md:grid-cols-3 md:gap-10">
        {caseStudies.map((item, i) => (
          <article class="reveal border-t rule pt-6">
            <p class="edition tabnum">№ {String(i + 1).padStart(2, "0")}</p>
            <h3 class="display mt-4 text-[1.6rem] leading-[1.1]" style="font-weight: 440; letter-spacing: -0.02em;">{item.title}</h3>
            <dl class="mt-6 space-y-5 text-[0.92rem] leading-[1.65]">
              <div>
                <dt class="eyebrow">Problem</dt>
                <dd class="mt-2" style="color: rgb(var(--muted));">{item.problem}</dd>
              </div>
              <div>
                <dt class="eyebrow">Build</dt>
                <dd class="mt-2" style="color: rgb(var(--muted));">{item.build}</dd>
              </div>
              <div>
                <dt class="eyebrow">Result</dt>
                <dd class="mt-2" style="color: rgb(var(--muted));">{item.result}</dd>
              </div>
            </dl>
            <a href={item.projectUrl} target="_blank" rel="noreferrer" class="text-link mt-6">
              {item.projectName} ↗
            </a>
          </article>
        ))}
      </div>
    </section>

    {/* ——— FOCUS / CTA ——— */}
    <section class="page-wrap mt-24 md:mt-32">
      <div class="grid gap-12 md:grid-cols-12">
        <div class="md:col-span-7">
          <p class="edition">№ 05 / Focus</p>
          <h2 class="display title-balance mt-6 text-[clamp(2rem,5.4vw,4rem)]">
            What I focus on.
          </h2>
          <p class="mt-6 max-w-xl text-[1.04rem] leading-[1.7]" style="color: rgb(var(--muted));">
            When a team is past the demo stage and trying to make something dependable: what the system should be trusted to do, where evidence should exist, and which trade-offs are worth making.
          </p>
          <p class="mt-5 max-w-xl text-[1.04rem] leading-[1.7]" style="color: rgb(var(--muted));">
            That tends to sit between engineering, product, and delivery. I like small teams, clear questions, and work that leaves a system easier to understand than it was before.
          </p>
        </div>
        <aside class="md:col-span-5">
          <div class="border-t rule pt-6">
            <p class="eyebrow">If this seems relevant</p>
            <h3 class="display mt-4 text-[1.9rem] leading-[1.1]" style="font-weight: 440; letter-spacing: -0.02em;">
              Write to me — a short note with context is enough.
            </h3>
            <p class="mt-5 text-[0.96rem] leading-[1.7]" style="color: rgb(var(--muted));">
              I read everything myself and prefer starting from a real problem, not a polished pitch.
            </p>
            <a href="/contact" class="btn-secondary mt-8">Start a conversation</a>
          </div>
        </aside>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
