---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ProjectCard from "../components/ProjectCard.astro";
import projects from "../content/projects.json";
import research from "../content/research.json";
import { filterProductProjects } from "../utils/researchSplit";

const productProjects = filterProductProjects(projects, research);
const languages = [...new Set(productProjects.map((p) => p.primaryLanguage).filter(Boolean))].sort();
---

<BaseLayout
  title="ali uyar // projects"
  canonicalPath="/projects"
  description="Selected projects around AI reliability, governance, evaluation, and the boring parts that make systems usable."
>
  <SiteHeader />
  <main id="main" class="page-wrap py-14 md:py-16">

    <section class="reveal">
      <p class="prompt mono-sm tabnum" style="text-transform: uppercase; letter-spacing: 0.12em; color: rgb(var(--muted));">
        ls -la ~/projects
      </p>
      <h1 class="page-title mt-6">projects<span class="caret" aria-hidden="true"></span></h1>
      <p class="mt-5 max-w-2xl copy-pretty" style="color: rgb(var(--muted)); line-height: 1.75;">
        Things I built around the awkward middle of AI work: data quality, audit trails, routing, privacy, cost, flaky tests, and all the other stuff that quietly decides whether a system survives real use.
      </p>

      <dl class="kv mt-8 max-w-sm">
        <dt>COUNT</dt>
        <dd class="tabnum accent">{String(productProjects.length).padStart(2, "0")}</dd>
        <dt>FILTERS</dt>
        <dd>query + language</dd>
        <dt>RELATED</dt>
        <dd><a class="link" href="/research">→ /research</a></dd>
      </dl>
    </section>

    {/* FILTERS */}
    <section class="mt-12 grid gap-6 md:grid-cols-[1fr_auto] md:items-end md:gap-10">
      <label class="block">
        <span class="label block mb-2">search</span>
        <span class="inline-flex w-full items-baseline gap-2">
          <span class="accent mono-sm">›</span>
          <input id="project-search" type="search" class="input" placeholder="by name or description…" />
        </span>
      </label>
      <label class="block md:min-w-[14rem]">
        <span class="label block mb-2">language</span>
        <select id="project-language" class="input cursor-pointer appearance-none">
          <option value="all">all</option>
          {languages.map((lang) => <option value={lang}>{lang}</option>)}
        </select>
      </label>
    </section>

    <div class="divider-ascii mt-12" aria-hidden="true">
      ────────────────────────────────────────────────────────────────────────────
    </div>

    <div id="project-grid" class="mt-4">
      {productProjects.map((project, i) => (
        <div class="project-item" data-project={JSON.stringify(project)}>
          <ProjectCard project={project} index={i} />
        </div>
      ))}
    </div>

    <p id="project-empty" class="mt-8 hidden label-accent">
      // no projects match your filters
    </p>
  </main>
  <SiteFooter />
</BaseLayout>

<script is:inline>
  (() => {
    const search = document.getElementById("project-search");
    const language = document.getElementById("project-language");
    const nodes = [...document.querySelectorAll(".project-item")];
    const empty = document.getElementById("project-empty");

    const run = () => {
      const q = (search.value || "").toLowerCase().trim();
      const lang = language.value;
      let visible = 0;

      for (const node of nodes) {
        const project = JSON.parse(node.dataset.project || "{}");
        const haystack = [project.name, project.description].join(" ").toLowerCase();
        const languageMatch = lang === "all" || project.primaryLanguage === lang;
        const queryMatch = !q || haystack.includes(q);

        const show = languageMatch && queryMatch;
        node.classList.toggle("hidden", !show);
        if (show) visible += 1;
      }

      empty.classList.toggle("hidden", visible > 0);
    };

    [search, language].forEach((el) => el?.addEventListener("input", run));
    run();
  })();
</script>
