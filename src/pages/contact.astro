---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import profile from "../content/profile.json";

const hasLinkedIn = Boolean(profile.linkedin && !profile.linkedin.includes("your-linkedin-handle"));
const primaryEmail = "contact@aliuyar.dev";
---

<BaseLayout title="Contact | Ali Uyar" canonicalPath="/contact" description="Contact Ali Uyar for consulting, product, and AI systems engagements.">
  <SiteHeader />
  <main id="main" class="page-wrap py-14">
    <h1 class="title-balance text-3xl font-semibold tracking-tight md:text-5xl">Contact</h1>
    <p class="copy-pretty mt-3 max-w-2xl text-sm text-[rgb(var(--muted))]">For consulting inquiries, hiring conversations, or collaboration opportunities.</p>

    <section class="mt-10 grid gap-4 md:grid-cols-3">
      <article class="card p-6">
        <h2 class="text-lg font-semibold tracking-tight">Email</h2>
        <ul class="mt-3 space-y-2 text-sm text-[rgb(var(--muted))]">
          <li><a class="focus-ring hover:underline" href={`mailto:${primaryEmail}`}>{primaryEmail}</a></li>
        </ul>
      </article>
      <article class="card p-6">
        <h2 class="text-lg font-semibold tracking-tight">Profiles</h2>
        <ul class="mt-3 space-y-2 text-sm text-[rgb(var(--muted))]">
          <li><a class="focus-ring hover:underline" href={profile.github} target="_blank" rel="noreferrer">GitHub</a></li>
          {hasLinkedIn && <li><a class="focus-ring hover:underline" href={profile.linkedin} target="_blank" rel="noreferrer">LinkedIn</a></li>}
        </ul>
      </article>
      <article class="card p-6">
        <h2 class="text-lg font-semibold tracking-tight">CV</h2>
        <p class="mt-3 text-sm text-[rgb(var(--muted))]">Download my CV in your preferred language.</p>
        <div class="mt-4 flex flex-wrap gap-2">
          <a
            href="/CV_AliUyar_English.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="focus-ring inline-flex items-center rounded-full border border-[rgb(var(--border))] px-4 py-2 text-xs font-semibold text-[rgb(var(--fg))] transition-colors hover:bg-surface-100 dark:hover:bg-surface-900"
          >
            English PDF
          </a>
          <a
            href="/CV_AliUyar_German.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="focus-ring inline-flex items-center rounded-full border border-[rgb(var(--border))] px-4 py-2 text-xs font-semibold text-[rgb(var(--fg))] transition-colors hover:bg-surface-100 dark:hover:bg-surface-900"
          >
            Deutsch PDF
          </a>
        </div>
      </article>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
