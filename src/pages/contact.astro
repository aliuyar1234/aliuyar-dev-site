---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import profile from "../content/profile.json";

const primaryEmail = "contact@aliuyar.dev";
---

<BaseLayout title="Contact | Ali Uyar" canonicalPath="/contact" description="Contact Ali Uyar for serious product, research, and AI systems conversations.">
  <SiteHeader />
  <main id="main" class="page-wrap max-w-4xl py-16 md:py-20">
    <section class="page-intro">
      <h1 class="title-balance text-4xl font-semibold tracking-tight md:text-6xl">Email is the best way to reach me.</h1>
      <p class="page-lede">
        The best emails are clear about the question, the context, and where the technical or product tension sits.
      </p>
    </section>

    <section class="mt-14 border-t border-[rgb(var(--border))/0.72] pt-8 md:grid md:grid-cols-5 md:gap-8">
      <div class="md:col-span-3">
        <a class="focus-ring text-2xl font-semibold tracking-tight hover:underline md:text-4xl" href={`mailto:${primaryEmail}`}>{primaryEmail}</a>
        <p class="mt-4 max-w-xl text-sm leading-7 text-[rgb(var(--muted))]">
          A short note with context, what you are building, and where the technical or product bottleneck sits is enough to start.
        </p>
      </div>

      <div class="mt-8 md:col-span-2 md:mt-0">
        <p class="text-xs font-medium uppercase tracking-[0.18em] text-[rgb(var(--muted))]">Best for</p>
        <ul class="mt-4 space-y-3 text-sm leading-relaxed text-[rgb(var(--muted))]">
          <li>AI systems that need sharper reliability, evaluation, or architecture decisions.</li>
          <li>Product work where technical depth and delivery judgment both matter.</li>
          <li>Research, writing, or collaboration inquiries with a clear shared question.</li>
        </ul>

        <div class="mt-6 flex items-center gap-4 text-sm text-[rgb(var(--muted))]">
          <a class="focus-ring transition-colors hover:text-[rgb(var(--fg))]" href={profile.github} target="_blank" rel="noreferrer">GitHub</a>
        </div>
      </div>
    </section>

    <section id="cv" class="mt-10 border-t border-[rgb(var(--border))/0.72] pt-5 text-sm text-[rgb(var(--muted))]">
      <p>
        If useful, my CV is available in
        <a class="focus-ring ml-1 transition-colors hover:text-[rgb(var(--fg))] hover:underline" href="/CV_AliUyar_English.pdf" target="_blank" rel="noopener noreferrer">English</a>
        and
        <a class="focus-ring ml-1 transition-colors hover:text-[rgb(var(--fg))] hover:underline" href="/CV_AliUyar_German.pdf" target="_blank" rel="noopener noreferrer">German</a>.
        I am currently in a full-time role and not taking new engagements; research, writing, and collaboration notes are still welcome.
      </p>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
