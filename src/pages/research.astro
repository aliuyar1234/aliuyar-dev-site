---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import projects from "../content/projects.json";
import research from "../content/research.json";
import { filterResearchProjects } from "../utils/researchSplit";

const researchRepos = filterResearchProjects(projects, research);
const researchJsonLd = research.map((paper) => ({
  "@context": "https://schema.org",
  "@type": "ScholarlyArticle",
  headline: paper.title,
  datePublished: `${paper.year}`,
  description: paper.abstract,
  author: (paper.authors || []).map((author) => ({
    "@type": "Person",
    name: author
  })),
  url: paper.paperUrl,
  sameAs: paper.pdfUrl || paper.paperUrl,
  isPartOf: {
    "@type": "WebSite",
    name: "aliuyar.dev",
    url: "https://aliuyar.dev"
  },
  identifier: paper.doi ? `https://doi.org/${paper.doi}` : undefined,
  keywords: (paper.tags || []).join(", ")
}));
---

<BaseLayout
  title="Research | Ali Uyar"
  canonicalPath="/research"
  description="Research papers and related research repositories by Ali Uyar."
  jsonLd={researchJsonLd}
>
  <SiteHeader />
  <main id="main" class="page-wrap py-14">
    <h1 class="title-balance text-3xl font-semibold tracking-tight md:text-5xl">Research</h1>
    <p class="copy-pretty mt-3 max-w-2xl text-sm leading-relaxed text-[rgb(var(--muted))]">Selected papers on LLM reliability, evaluation, and robust systems.</p>

    <section class="mt-10">
      <h2 class="text-2xl font-semibold tracking-tight">Papers</h2>
      <div class="mt-4 grid gap-4">
        {research.map((paper) => {
          return (
          <article class="card p-6">
            <p class="text-xs text-[rgb(var(--muted))]">{paper.year}</p>
            <h3 class="mt-2 text-2xl font-semibold tracking-tight">{paper.title}</h3>
            <p class="mt-2 text-sm text-[rgb(var(--muted))]">{paper.abstract}</p>
            {paper.whyItMatters && <p class="mt-2 text-sm text-[rgb(var(--fg))]"><span class="font-medium">Why this matters:</span> {paper.whyItMatters}</p>}
            <p class="mt-3 text-xs text-[rgb(var(--muted))]">Authors: {paper.authors.join(", ")}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {(paper.tags || []).map((tag) => <span class="rounded-full border border-[rgb(var(--border))] px-2.5 py-1 text-xs text-[rgb(var(--muted))]">{tag}</span>)}
            </div>
            {paper.doi && (
              <p class="mt-3 text-xs text-[rgb(var(--muted))]">
                DOI:
                <a class="focus-ring ml-1 text-accent-500 hover:underline" href={`https://doi.org/${paper.doi}`} target="_blank" rel="noreferrer">
                  {paper.doi}
                </a>
              </p>
            )}
            <div class="mt-5 flex items-center gap-4 text-sm">
              {paper.doi && <a class="focus-ring text-accent-500 hover:underline" href={`https://doi.org/${paper.doi}`} target="_blank" rel="noreferrer">DOI</a>}
              {paper.pdfUrl && <a class="focus-ring text-accent-500 hover:underline" href={paper.pdfUrl} target="_blank" rel="noreferrer">PDF</a>}
              {!paper.doi && paper.paperUrl && paper.paperUrl !== paper.codeUrl && (
                <a class="focus-ring text-accent-500 hover:underline" href={paper.paperUrl} target="_blank" rel="noreferrer">Paper</a>
              )}
              {paper.codeUrl && <a class="focus-ring text-accent-500 hover:underline" href={paper.codeUrl} target="_blank" rel="noreferrer">Code</a>}
            </div>
          </article>
        )})}
      </div>
    </section>

    <section class="mt-14">
      <h2 class="text-2xl font-semibold tracking-tight">Research Repositories</h2>
      <p class="mt-2 text-sm text-[rgb(var(--muted))]">Related code and experiment repositories.</p>
      <div class="mt-4 grid gap-3 md:grid-cols-2">
        {researchRepos.map((repo) => (
          <article class="rounded-2xl border border-[rgb(var(--border))] p-5">
            <h3 class="text-lg font-semibold tracking-tight"><a class="focus-ring hover:underline" href={repo.url} target="_blank" rel="noreferrer">{repo.name}</a></h3>
            <p class="mt-2 text-sm text-[rgb(var(--muted))]">{repo.description || "No description provided."}</p>
          </article>
        ))}
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
