---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import research from "../content/research.json";

const researchJsonLd = research.map((paper) => ({
  "@context": "https://schema.org",
  "@type": "ScholarlyArticle",
  headline: paper.title,
  datePublished: `${paper.year}`,
  description: paper.abstract,
  author: (paper.authors || []).map((author) => ({
    "@type": "Person",
    name: author
  })),
  url: paper.paperUrl,
  sameAs: paper.pdfUrl || paper.paperUrl,
  isPartOf: {
    "@type": "WebSite",
    name: "aliuyar.dev",
    url: "https://aliuyar.dev"
  },
  identifier: paper.doi ? `https://doi.org/${paper.doi}` : undefined,
  keywords: (paper.tags || []).join(", ")
}));
---

<BaseLayout
  title="Research — Ali Uyar"
  canonicalPath="/research"
  description="Research papers and related research repositories by Ali Uyar."
  jsonLd={researchJsonLd}
>
  <SiteHeader />
  <main id="main" class="page-wrap py-16 md:py-24">
    <section class="grid items-end gap-10 md:grid-cols-12">
      <div class="md:col-span-8">
        <p class="edition">№ 03 / Papers</p>
        <h1 class="display title-balance mt-6 text-[clamp(2.5rem,7vw,6rem)]">
          Research<span class="display-italic" style="color: rgb(var(--muted));">.</span>
        </h1>
        <p class="page-lede">
          Papers that came out of questions I keep returning to — around reliability, evaluation, and how to make AI systems easier to inspect and reason about.
        </p>
      </div>
      <div class="md:col-span-4">
        <div class="border-t rule pt-6">
          <p class="eyebrow">Volume</p>
          <div class="mt-4 flex items-baseline justify-between">
            <span class="font-mono text-[0.72rem] uppercase tracking-[0.2em]" style="color: rgb(var(--muted));">Papers</span>
            <span class="font-display tabnum text-[1.5rem]" style="font-weight: 440;">{String(research.length).padStart(2, "0")}</span>
          </div>
          <a href="/projects" class="text-link mt-5">Related projects →</a>
        </div>
      </div>
    </section>

    <section class="mt-14">
      {research.map((paper, i) => (
        <article class="paper-card reveal">
          <div class="grid gap-6 md:grid-cols-[auto_1fr] md:gap-10">
            <div class="font-mono tabnum text-[0.72rem] uppercase tracking-[0.2em] md:min-w-[7rem]" style="color: rgb(var(--muted));">
              <div>№ {String(i + 1).padStart(2, "0")}</div>
              <div class="mt-2">{paper.year}</div>
            </div>

            <div>
              <h3>{paper.title}</h3>
              <p class="mt-4 text-[1.02rem] leading-[1.7]" style="color: rgb(var(--muted));">{paper.abstract}</p>

              {paper.whyItMatters && (
                <blockquote class="relative mt-6 border-l pl-5 italic" style="border-color: rgb(var(--accent)); color: rgb(var(--fg));">
                  <span class="font-mono not-italic text-[0.66rem] uppercase tracking-[0.22em]" style="color: rgb(var(--accent-ink));">Operational relevance</span>
                  <p class="mt-2 font-display text-[1.05rem] leading-[1.55]" style="font-weight: 420;">{paper.whyItMatters}</p>
                </blockquote>
              )}

              <p class="mt-6 font-mono text-[0.72rem] uppercase tracking-[0.18em]" style="color: rgb(var(--muted));">
                {paper.authors.join(" · ")}
              </p>

              <div class="mt-5 flex flex-wrap gap-2">
                {(paper.tags || []).map((tag) => <span class="chip">{tag}</span>)}
              </div>

              <div class="mt-6 flex flex-wrap items-center gap-5">
                {paper.doi && <a class="text-link" href={`https://doi.org/${paper.doi}`} target="_blank" rel="noreferrer">DOI ↗</a>}
                {paper.pdfUrl && <a class="text-link" href={paper.pdfUrl} target="_blank" rel="noreferrer">PDF ↗</a>}
                {!paper.doi && paper.paperUrl && paper.paperUrl !== paper.codeUrl && (
                  <a class="text-link" href={paper.paperUrl} target="_blank" rel="noreferrer">Paper ↗</a>
                )}
                {paper.codeUrl && <a class="text-link" href={paper.codeUrl} target="_blank" rel="noreferrer">Code ↗</a>}
              </div>
            </div>
          </div>
        </article>
      ))}
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
