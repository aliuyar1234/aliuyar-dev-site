---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import research from "../content/research.json";

const researchJsonLd = research.map((paper) => ({
  "@context": "https://schema.org",
  "@type": "ScholarlyArticle",
  headline: paper.title,
  datePublished: `${paper.year}`,
  description: paper.abstract,
  author: (paper.authors || []).map((author) => ({
    "@type": "Person",
    name: author
  })),
  url: paper.paperUrl,
  sameAs: paper.pdfUrl || paper.paperUrl,
  isPartOf: {
    "@type": "WebSite",
    name: "aliuyar.dev",
    url: "https://aliuyar.dev"
  },
  identifier: paper.doi ? `https://doi.org/${paper.doi}` : undefined,
  keywords: (paper.tags || []).join(", ")
}));
---

<BaseLayout
  title="ali uyar // research"
  canonicalPath="/research"
  description="Research papers and related research repositories by Ali Uyar."
  jsonLd={researchJsonLd}
>
  <SiteHeader />
  <main id="main" class="page-wrap py-14 md:py-16">

    <section class="reveal">
      <p class="prompt mono-sm tabnum" style="text-transform: uppercase; letter-spacing: 0.12em; color: rgb(var(--muted));">
        cat ~/research/index.md
      </p>
      <h1 class="page-title mt-6">research<span class="caret" aria-hidden="true"></span></h1>
      <p class="mt-5 max-w-2xl copy-pretty" style="color: rgb(var(--muted)); line-height: 1.75;">
        Papers that came out of questions I keep returning to — around reliability, evaluation, and how to make AI systems easier to inspect and reason about.
      </p>

      <dl class="kv mt-8 max-w-sm">
        <dt>PAPERS</dt>
        <dd class="tabnum accent">{String(research.length).padStart(2, "0")}</dd>
        <dt>YEAR</dt>
        <dd>2026</dd>
        <dt>RELATED</dt>
        <dd><a class="link" href="/projects">→ /projects</a></dd>
      </dl>
    </section>

    <div class="divider-ascii mt-12" aria-hidden="true">
      ════════════════════════════════════════════════════════════════════════════
    </div>

    <section class="mt-2">
      {research.map((paper, i) => (
        <article class="row reveal" style="padding: 1.5rem 0.75rem;">
          <div class="idx">
            № {String(i + 1).padStart(2, "0")}<br />
            <span style="color: rgb(var(--dim)); letter-spacing: 0.1em;">{paper.year}</span>
          </div>

          <div>
            <h2 class="title" style="font-size: 1.06rem; line-height: 1.45;">
              <a class="link-accent" href={paper.pdfUrl || paper.paperUrl} target="_blank" rel="noreferrer">
                {paper.title}
              </a>
            </h2>

            <p class="desc">{paper.abstract}</p>

            {paper.whyItMatters && (
              <div class="mt-4 pl-4" style="border-left: 2px solid rgb(var(--accent));">
                <p class="label-accent">// operational relevance</p>
                <p class="mt-1 text-[0.95rem] leading-[1.7]">{paper.whyItMatters}</p>
              </div>
            )}

            <p class="mt-4 mono-xs tabnum" style="color: rgb(var(--muted));">
              authors: {paper.authors.join(" · ")}
            </p>

            <div class="mt-3 flex flex-wrap gap-1.5">
              {(paper.tags || []).map((tag) => <span class="tag">{tag}</span>)}
            </div>

            <div class="mt-4 flex flex-wrap items-center gap-4 mono-sm">
              {paper.doi && <a class="link-muted" href={`https://doi.org/${paper.doi}`} target="_blank" rel="noreferrer">→ doi</a>}
              {paper.pdfUrl && <a class="link-muted" href={paper.pdfUrl} target="_blank" rel="noreferrer">→ pdf</a>}
              {!paper.doi && paper.paperUrl && paper.paperUrl !== paper.codeUrl && (
                <a class="link-muted" href={paper.paperUrl} target="_blank" rel="noreferrer">→ paper</a>
              )}
              {paper.codeUrl && <a class="link-muted" href={paper.codeUrl} target="_blank" rel="noreferrer">→ code</a>}
            </div>
          </div>

          <div class="meta">
            {paper.doi && <div class="tabnum">DOI</div>}
          </div>
        </article>
      ))}
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
