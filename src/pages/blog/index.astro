---
import BaseLayout from "../../layouts/BaseLayout.astro";

const target = "/articles";
---

<BaseLayout title="Articles | Ali Uyar" canonicalPath="/articles" description="This page moved to /articles.">
  <main id="main" class="page-wrap py-16">
    <section class="section-shell max-w-2xl">
      <h1 class="text-2xl font-semibold tracking-tight md:text-4xl">Moved to Articles</h1>
      <p class="mt-3 text-sm text-[rgb(var(--muted))]">This page moved to <a class="focus-ring underline" href={target}>{target}</a>.</p>
      <a class="btn-primary mt-5" href={target}>Continue</a>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  (() => {
    if (window.location.pathname === "/blog" || window.location.pathname === "/blog/") {
      window.location.replace("/articles");
    }
  })();
</script>
