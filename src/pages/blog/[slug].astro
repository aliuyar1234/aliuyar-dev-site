---
import BaseLayout from "../../layouts/BaseLayout.astro";
import writing from "../../content/writing.json";

interface BlogPost {
  slug: string;
}

export function getStaticPaths() {
  return [...(writing as BlogPost[])].map((post) => ({
    params: { slug: post.slug },
    props: { target: `/articles/${post.slug}` }
  }));
}

const { target } = Astro.props as { target: string };
---

<BaseLayout title="Articles | Ali Uyar" canonicalPath={target} description="This page moved to /articles.">
  <main id="main" class="page-wrap py-16">
    <section class="section-shell max-w-2xl">
      <h1 class="text-2xl font-semibold tracking-tight md:text-4xl">Moved to Articles</h1>
      <p class="mt-3 text-sm text-[rgb(var(--muted))]">This article moved to <a class="focus-ring underline" href={target}>{target}</a>.</p>
      <a class="btn-primary mt-5" href={target}>Continue</a>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  (() => {
    const target = {JSON.stringify(target)};
    if (target) {
      window.location.replace(target);
    }
  })();
</script>
