---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout title="Articles | Ali Uyar" canonicalPath="/articles" description="The writing page has moved to /articles.">
  <SiteHeader />
  <main id="main" class="page-wrap py-14">
    <section class="section-shell max-w-3xl">
      <h1 class="title-balance text-3xl font-semibold tracking-tight md:text-5xl">Writing has moved</h1>
      <p class="copy-pretty mt-4 text-sm leading-relaxed text-[rgb(var(--muted))]">
        The updated articles now live at <a class="focus-ring underline" href="/articles">/articles</a>, with individual pages for each entry.
      </p>
      <a href="/articles" class="btn-primary mt-6">Go to Articles</a>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

