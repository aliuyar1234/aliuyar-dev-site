---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import writing from "../content/writing.json";
---

<BaseLayout title="Writing | Ali Uyar" canonicalPath="/writing" description="Notes on AI systems, product strategy, and reliable delivery.">
  <SiteHeader />
  <main id="main" class="page-wrap py-14">
    <h1 class="text-3xl font-semibold tracking-tight md:text-5xl">Writing</h1>
    <p class="mt-3 max-w-2xl text-sm text-[rgb(var(--muted))]">Short notes and essays on reliable AI systems, technical product work, and decision quality.</p>

    <section class="mt-10 grid gap-4">
      {writing.map((entry) => (
        <article class="card p-6">
          <p class="text-xs text-[rgb(var(--muted))]">{new Date(entry.date).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}</p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight">{entry.title}</h2>
          <p class="mt-2 text-sm text-[rgb(var(--muted))]">{entry.summary}</p>
        </article>
      ))}
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

