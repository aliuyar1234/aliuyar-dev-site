---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout title="Blog | Ali Uyar" canonicalPath="/blog" description="The writing page has moved to /blog.">
  <SiteHeader />
  <main id="main" class="page-wrap py-14">
    <section class="section-shell max-w-3xl">
      <h1 class="title-balance text-3xl font-semibold tracking-tight md:text-5xl">Blog has moved</h1>
      <p class="copy-pretty mt-4 text-sm leading-relaxed text-[rgb(var(--muted))]">
        The updated blog now lives at <a class="focus-ring underline" href="/blog">/blog</a>, with individual article pages for each post.
      </p>
      <a href="/blog" class="btn-primary mt-6">Go to Blog</a>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

