---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout title="Page Not Found | Ali Uyar" canonicalPath="/404" description="The page you requested could not be found.">
  <SiteHeader />
  <main id="main" class="page-wrap flex min-h-[60vh] flex-col items-start justify-center py-14">
    <p class="text-sm text-[rgb(var(--muted))]">404</p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight md:text-5xl">Page not found</h1>
    <p class="mt-3 text-sm text-[rgb(var(--muted))]">The requested page doesn’t exist or has moved.</p>
    <a href="/" class="btn-primary mt-6">Back to home</a>
  </main>
  <SiteFooter />
</BaseLayout>
