---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout title="Page Not Found — Ali Uyar" canonicalPath="/404" description="The page you requested could not be found.">
  <SiteHeader />
  <main id="main" class="page-wrap flex min-h-[70vh] flex-col items-start justify-center py-20">
    <p class="edition">Status · 404</p>
    <h1 class="display mt-6 text-[clamp(3rem,10vw,8rem)] leading-[0.95]">
      Not <span class="display-italic">here</span>.
    </h1>
    <p class="mt-6 max-w-xl text-[1.04rem] leading-[1.7]" style="color: rgb(var(--muted));">
      The requested page does not exist, or it has moved. If you arrived from an old link, the index is the best place to start.
    </p>
    <div class="mt-10 flex flex-wrap items-center gap-4">
      <a href="/" class="btn-primary">Back to index</a>
      <a href="/projects" class="btn-secondary">See projects</a>
    </div>
  </main>
  <SiteFooter />
</BaseLayout>
