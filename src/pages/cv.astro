---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout title="CV | Ali Uyar" canonicalPath="/cv" description="Curriculum vitae and profile summary for Ali Uyar.">
  <SiteHeader />
  <main id="main" class="page-wrap max-w-3xl py-14">
    <h1 class="text-3xl font-semibold tracking-tight md:text-5xl">Curriculum Vitae</h1>
    <p class="mt-4 text-sm leading-relaxed text-[rgb(var(--muted))]">Place your final CV PDF in <code>public/cv.pdf</code> (recommended source filename: <code>CV_AliUyar.pdf</code>) to activate the download link.</p>

    <section class="section-shell mt-8">
      <h2 class="text-xl font-semibold tracking-tight">Quick Summary</h2>
      <ul class="mt-3 space-y-2 text-sm text-[rgb(var(--muted))]">
        <li>AI Systems and technical product specialist</li>
        <li>Focus on reliability, governance, and measurable outcomes</li>
        <li>Available for consulting and selected full-time opportunities</li>
      </ul>
      <a href="/cv.pdf" class="btn-primary mt-5">Download PDF</a>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
