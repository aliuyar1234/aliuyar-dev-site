---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

const services = [
  {
    num: "01",
    title: "System Review",
    kicker: "For teams that need clarity on architecture, reliability, and what to fix first.",
    outcomes: [
      "A clearer picture of the main technical risks.",
      "A practical list of what matters now and what can wait.",
      "A sharper direction for the next steps."
    ]
  },
  {
    num: "02",
    title: "Implementation",
    kicker: "For teams that know the direction and need the work to become disciplined and reliable.",
    outcomes: [
      "AI workflows that are more stable and easier to evaluate.",
      "Checks and measurement built into the work.",
      "A handover the team can actually use."
    ]
  },
  {
    num: "03",
    title: "Advisory",
    kicker: "For teams that want sharper product, architecture, or sequencing decisions before committing further.",
    outcomes: [
      "Clearer decisions before time and money are spent in the wrong place.",
      "Less confusion about where AI helps and where it does not.",
      "Technical product input that works for both builders and decision-makers."
    ]
  }
];

const principles = [
  { num: "i.",  head: "Understand the problem.",   body: "We get clear on the real issue, not just the symptoms around it." },
  { num: "ii.", head: "Keep the scope tight.",     body: "We decide what is worth doing now and what can wait." },
  { num: "iii.",head: "Leave something useful.",   body: "The result should still help the team after the engagement ends." }
];
---

<BaseLayout
  title="Services — Ali Uyar"
  canonicalPath="/services"
  description="Ways Ali Uyar helps teams with AI systems, technical product decisions, and reliable delivery."
>
  <SiteHeader />
  <main id="main" class="page-wrap py-16 md:py-24">
    <section class="grid items-end gap-10 md:grid-cols-12">
      <div class="md:col-span-9">
        <p class="edition">№ 04 / Engagements</p>
        <h1 class="display title-balance mt-6 text-[clamp(2.5rem,7vw,6rem)]">
          What I <span class="display-italic">do</span>.
        </h1>
        <p class="page-lede">
          I help teams get clear on the real problem — whether it is already visible, or only starting to show up.
        </p>
      </div>
    </section>

    <section class="mt-16 md:mt-20">
      <div class="grid gap-10 md:grid-cols-3 md:gap-14">
        {services.map((s) => (
          <article class="reveal border-t rule pt-6">
            <p class="edition tabnum">№ {s.num}</p>
            <h2 class="display mt-4 text-[1.9rem] leading-[1.05]" style="font-weight: 440; letter-spacing: -0.02em;">{s.title}</h2>
            <p class="mt-5 text-[0.98rem] leading-[1.7]" style="color: rgb(var(--muted));">{s.kicker}</p>
            <p class="eyebrow mt-8">Typical outcomes</p>
            <ul class="mt-4 space-y-3">
              {s.outcomes.map((out) => (
                <li class="flex gap-3 text-[0.95rem] leading-[1.65]" style="color: rgb(var(--muted));">
                  <span class="font-mono text-[0.68rem] uppercase tracking-[0.2em] pt-1" style="color: rgb(var(--accent));">—</span>
                  <span>{out}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-24 md:mt-32">
      <div class="section-head">
        <span class="edition">Method</span>
        <h2 class="display">How I work.</h2>
        <span class="edition hidden md:inline">Small, tight, useful</span>
      </div>

      <div class="grid gap-12 md:grid-cols-12">
        <p class="md:col-span-5 text-[1.04rem] leading-[1.7]" style="color: rgb(var(--muted));">
          I prefer small engagements with a clear question or bottleneck. Less theatre, more signal.
        </p>
        <ol class="md:col-span-7 space-y-8">
          {principles.map((p) => (
            <li class="grid grid-cols-[auto_1fr] gap-6 border-t rule pt-6">
              <span class="font-mono tabnum text-[0.78rem] uppercase tracking-[0.2em]" style="color: rgb(var(--accent));">{p.num}</span>
              <div>
                <p class="font-display text-[1.35rem] leading-[1.25]" style="font-weight: 440; letter-spacing: -0.02em;">{p.head}</p>
                <p class="mt-2 text-[0.98rem] leading-[1.7]" style="color: rgb(var(--muted));">{p.body}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="mt-24 md:mt-32 border-t rule pt-10">
      <p class="text-[1.04rem] leading-[1.7]" style="color: rgb(var(--muted));">
        If this seems relevant, the easiest way to start is an email on the
        <a href="/contact" class="text-link">contact page</a>.
      </p>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
