---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

const services = [
  {
    num: "01",
    slug: "system_review",
    title: "Reality Check",
    kicker: "For teams with an AI workflow that looks promising but feels a bit too fragile to trust.",
    outcomes: [
      "A clear view of what is actually risky, not just what is loud.",
      "A short list of what to fix now, what to ignore, and what to stop pretending is fine.",
      "A next step that does not require a religious debate about architecture."
    ]
  },
  {
    num: "02",
    slug: "implementation",
    title: "Implementation",
    kicker: "For teams that know roughly what they want, but need the workflow to stop being a pile of clever exceptions.",
    outcomes: [
      "Workflows with fewer magic corners and better failure boundaries.",
      "Checks, evals, and traces built into the thing itself.",
      "A handover that does not require archaeology three weeks later."
    ]
  },
  {
    num: "03",
    slug: "advisory",
    title: "Advisory",
    kicker: "For teams deciding whether to build, cut, simplify, or move the problem somewhere less painful.",
    outcomes: [
      "Clearer decisions before the team spends another month polishing the wrong layer.",
      "Less confusion about where AI helps, where it hurts, and where plain workflow design wins.",
      "Product judgment that builders can use and decision-makers can understand."
    ]
  }
];

const method = [
  { k: "i.",   h: "Understand the problem.",   b: "Find the actual constraint, not the impressive-looking symptom around it." },
  { k: "ii.",  h: "Keep the scope tight.",     b: "Keep the loop small enough that the team can learn something real." },
  { k: "iii.", h: "Leave something useful.",   b: "Leave behind something inspectable: notes, checks, decisions, or a cleaner system." }
];
---

<BaseLayout
  title="ali uyar // services"
  canonicalPath="/services"
  description="How Ali Uyar helps teams get AI systems out of demo-land and into something safer, clearer, and easier to judge."
>
  <SiteHeader />
  <main id="main" class="page-wrap py-14 md:py-16">

    <section class="reveal">
      <p class="prompt mono-sm tabnum" style="text-transform: uppercase; letter-spacing: 0.12em; color: rgb(var(--muted));">
        man aliuyar.services
      </p>
      <h1 class="page-title mt-6">what i do<span class="caret" aria-hidden="true"></span></h1>
      <p class="mt-5 max-w-2xl copy-pretty" style="color: rgb(var(--muted)); line-height: 1.75;">
        I help teams get out of demo-land: what is actually broken, what needs evidence, and what should probably be simpler before anyone adds more AI.
      </p>
    </section>

    <div class="divider-ascii mt-14" aria-hidden="true">
      ── SYNOPSIS ────────────────────────────────────────────────────────────────
    </div>

    <section class="mt-8">
      <div class="grid gap-8 md:grid-cols-3 md:gap-10">
        {services.map((s) => (
          <article class="reveal" style="border: 1px solid var(--rule); padding: 1.5rem;">
            <p class="mono-xs tabnum" style="color: rgb(var(--accent));">mode.{s.num}</p>
            <h2 class="mt-4 font-mono text-[1.15rem]" style="font-weight: 500; letter-spacing: -0.005em;">
              {s.title}
            </h2>
            <p class="mt-4 text-[0.92rem] leading-[1.7]" style="color: rgb(var(--muted));">
              {s.kicker}
            </p>
            <p class="mt-6 label">[ typical outcomes ]</p>
            <ul class="mt-3 space-y-2 font-mono text-[0.88rem] leading-[1.65]" style="color: rgb(var(--muted));">
              {s.outcomes.map((out) => (
                <li class="flex gap-2">
                  <span class="accent">›</span>
                  <span>{out}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <div class="divider-ascii mt-20" aria-hidden="true">
      ── METHOD ──────────────────────────────────────────────────────────────────
    </div>

    <section class="mt-8 grid gap-10 md:grid-cols-12 md:gap-12">
      <div class="md:col-span-5">
        <p class="prompt-plain mono-xs tabnum" style="text-transform: uppercase; letter-spacing: 0.12em; color: rgb(var(--muted));">
          how i work
        </p>
        <p class="mt-5 text-[1rem] leading-[1.75]" style="color: rgb(var(--muted));">
          // small engagements with a clear question or bottleneck. less theatre, more signal.
        </p>
      </div>

      <ol class="md:col-span-7 space-y-6">
        {method.map((p) => (
          <li class="pl-5 pt-5" style="border-top: 1px solid var(--rule);">
            <div class="flex items-baseline gap-3">
              <span class="mono-xs tabnum" style="color: rgb(var(--accent));">{p.k}</span>
              <span class="font-mono text-[1.02rem]" style="font-weight: 500;">{p.h}</span>
            </div>
            <p class="mt-2 text-[0.92rem] leading-[1.7]" style="color: rgb(var(--muted));">
              {p.b}
            </p>
          </li>
        ))}
      </ol>
    </section>

    <section class="mt-20 pt-6" style="border-top: 1px solid var(--rule);">
      <p class="text-[0.98rem] leading-[1.75]" style="color: rgb(var(--muted));">
        // if this seems relevant, the easiest way to start is an email on the
        <a href="/contact" class="link">/contact</a>
        page.
      </p>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
