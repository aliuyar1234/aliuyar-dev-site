---
import "../styles.css";
import profile from "../content/profile.json";

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description = profile.summary,
  canonicalPath = "/",
  jsonLd = []
} = Astro.props as Props;

const normalizeCanonicalPath = (path: string) => {
  const match = path.match(/^([^?#]*)(.*)$/);
  const pathname = match?.[1] || path;
  const suffix = match?.[2] || "";

  if (pathname === "/" || /\.[a-z0-9]+$/i.test(pathname)) {
    return `${pathname}${suffix}`;
  }

  return `${pathname.replace(/\/+$/, "")}${suffix}`;
};

const canonicalPathname = canonicalPath.startsWith("/") ? canonicalPath : `/${canonicalPath}`;
const canonicalUrl = new URL(normalizeCanonicalPath(canonicalPathname), Astro.site).toString();
const ogImage = new URL("/og-default.svg", Astro.site).toString();
const socialProfiles = [profile.github].filter(Boolean);

const baseJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: profile.name,
    url: Astro.site?.toString() || canonicalUrl,
    jobTitle: "AI Systems Engineer",
    knowsAbout: ["AI Systems", "Technical Product", "LLM Reliability", "Agentic Systems"],
    sameAs: socialProfiles
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: profile.brand,
    url: Astro.site?.toString() || canonicalUrl
  }
];

const pageJsonLd = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
const allJsonLd = [...baseJsonLd, ...pageJsonLd].filter(Boolean);
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#0a0a09" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f7f5f0" media="(prefers-color-scheme: light)" />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,300..700;1,300..700&display=swap"
    />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={profile.brand} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {allJsonLd.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}

    <script is:inline>
      // Terminal default = dark. '.light' class overrides to paper.
      (() => {
        const key = "theme";
        const stored = localStorage.getItem(key);
        const prefersLight = window.matchMedia("(prefers-color-scheme: light)").matches;
        const theme = stored || (prefersLight ? "light" : "dark");
        document.documentElement.classList.toggle("light", theme === "light");
      })();
    </script>

    <title>{title}</title>
  </head>
  <body class="min-h-full">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 btn">Skip to content</a>
    <slot />
  </body>
</html>
